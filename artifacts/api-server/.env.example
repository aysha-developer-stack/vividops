# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/vivid_ops"

# --- Redis & Background Jobs (optional) ---
# Use rediss:// for Upstash/TLS. App runs without Redis; attachment queue jobs are skipped.
REDIS_URL="redis://localhost:6379"

# --- AWS S3 File Storage ---
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
AWS_S3_BUCKET="vivid-ops-files"

# --- Email (Resend) ---
RESEND_API_KEY="re_123456789"

# --- App Config ---
PORT=3000
NODE_ENV=development
SESSION_SECRET="your_random_secret_string"

# --- Zoho Cliq (AU data center example) ---
# Accounts (OAuth) base domain. For AU use https://accounts.zoho.com.au
ZOHO_ACCOUNTS_DOMAIN="https://accounts.zoho.com.au"
# Cliq REST API base. For AU use https://cliq.zoho.com.au/api/v2
ZOHO_CLIQ_API_ROOT="https://cliq.zoho.com.au/api/v2"
# Cliq web base (used to build clickable channel URLs)
ZOHO_CLIQ_WEB_ROOT="https://cliq.zoho.com.au"
# Company unique name from Cliq URL: https://cliq.zoho.com.au/company/<unique>/channels/...
ZOHO_CLIQ_COMPANY_UNIQUE_NAME="your-company-unique-name"
# Channel level for create channel API. For job chats, "private" is recommended.
ZOHO_CLIQ_CHANNEL_LEVEL="private"
# Secret used by the incoming Cliq -> app sync callback endpoint.
ZOHO_CLIQ_SYNC_SECRET="change-me"
# OAuth client created in Zoho API Console (server-based application)
ZOHO_CLIENT_ID="1000.xxxxx"
ZOHO_CLIENT_SECRET="xxxxxxxx"
# Redirect URI configured in Zoho API Console (must match exactly)
ZOHO_REDIRECT_URI="http://localhost:3001/api/zoho/callback"
# After OAuth consent, save the refresh token here (keep secret)
ZOHO_CLIQ_REFRESH_TOKEN="1000.xxxxx"
# Optional: legacy access token (not recommended; short-lived)
ZOHO_CLIQ_OAUTH_TOKEN=""
